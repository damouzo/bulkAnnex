/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    bulkAnnex Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    https://www.nextflow.io/docs/latest/config.html
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

nextflow.enable.dsl = 2

// Global default params
params {
    // ── Mandatory inputs ──────────────────────────────────────────────────────
    input        = null   // samplesheet.csv
    counts       = null   // salmon.merged.gene_counts.tsv
    contrasts    = null   // contrasts.csv
    organism     = null   // 'human' or 'mouse'

    // ── Output ────────────────────────────────────────────────────────────────
    outdir       = 'results'

    // ── DESeq2 parameters ─────────────────────────────────────────────────────
    min_counts        = 10      // min count sum per gene to pass pre-filter
    min_samples       = 2       // min samples with >= min_counts
    normalization     = 'vst'   // 'vst' or 'rlog'
    padj_threshold    = 0.05
    lfc_threshold     = 1.0

    // ── Analysis switches ─────────────────────────────────────────────────────
    run_gsea          = true
    skip_dashboard    = false
    gsea_pval_cutoff  = 0.05
    gsea_min_gs_size  = 15
    gsea_max_gs_size  = 500

    // ── Resource limits ───────────────────────────────────────────────────────
    max_memory        = '128.GB'
    max_cpus          = 16
    max_time          = '240.h'

    // ── Work directory ────────────────────────────────────────────────────────
    // Override on the CLI with --work_dir /path/to/scratch (or Nextflow's -w flag).
    // When null, falls back to ./work or the profile-specific workDir.
    work_dir          = null

    // ── Container ─────────────────────────────────────────────────────────────
    // Single container used by all processes.
    // Default: DockerHub image (used by docker/conda profiles and as fallback).
    // Singularity profile overrides this to the local SIF (see profiles block).
    // To rebuild Docker image: edit Dockerfile, bump version label, then:
    //   git add containers/bulkannex_r/Dockerfile
    //   git commit -m "chore: bump container to vX.Y.Z"
    //   git tag vX.Y.Z && git push && git push --tags
    // GitHub Actions (.github/workflows/docker.yml) builds and pushes to DockerHub automatically.
    // To rebuild Apptainer SIF: sbatch containers/bulkannex_r/submit_build.sh
    // Override at runtime: --container /path/to/custom.sif
    container = "docker.io/damouzo/bulkannex_r:1.0.2"

    // ── Boilerplate ───────────────────────────────────────────────────────────
    publish_dir_mode  = 'copy'
    monochrome_logs   = false
    help              = false
    version           = false
}

// Apply --work_dir param if provided (overrides profile defaults)
if (params.work_dir) { workDir = params.work_dir }

// Import subconfigs
includeConfig 'conf/base.config'

// Load genome-specific config
includeConfig 'conf/genomes.config'

// Load module-level publishDir / ext.args
includeConfig 'conf/modules.config'

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }

    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        process.conda           = "${projectDir}/containers/bulkannex_r/environment.yml"
    }

    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        // Cache directory for auto-pulled images (shared across compute nodes via GPFS).
        singularity.cacheDir    = "/gpfs/scratch/${System.getenv('USER')}/singularity_cache"
        // Always reference the local SIF path.
        // If the SIF does not exist yet, SINGULARITY_PULL (the first pipeline process)
        // will pull it on a compute node before any containerised process runs.
        params.container        = "${projectDir}/containers/bulkannex_r/bulkannex_r_1.0.2.sif"
    }

    test {
        includeConfig 'conf/test.config'
    }

    // ── HPC profiles ──────────────────────────────────────────────────────────
    slurm {
        process.executor        = 'slurm'
        executor.queueSize      = 50
        executor.submitRateLimit = '10/1min'
    }

    apocrita {
        process.executor        = 'slurm'
        process.queue           = 'compute'    // Apocrita partitions: compute, computeshort, highmem
        executor.queueSize      = 100
        executor.submitRateLimit = '10/1min'
        params.max_memory        = '512.GB'
        params.max_cpus          = 32
        params.max_time          = '240.h'
        // Work dir on GPFS scratch to avoid filling home or project quota
        workDir                  = "/gpfs/scratch/${System.getenv('USER')}/bulkannex_work"
    }

    local {
        process.executor        = 'local'
        params.max_memory        = '16.GB'
        params.max_cpus          = 4
        params.max_time          = '24.h'
    }
}

// ── Execution reports ──────────────────────────────────────────────────────────
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag_${trace_timestamp}.html"
    overwrite = true
}

// ── Manifest ──────────────────────────────────────────────────────────────────
manifest {
    name            = 'bulkAnnex'
    author          = 'BCI-KRP'
    homePage        = 'https://github.com/BCI-KRP/bulkAnnex'
    description     = 'Automated bulkRNA-seq analysis Nextflow pipeline with an interactive dashboard'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0dev'
    doi             = ''
}

// check_max is defined in conf/base.config where it is used
