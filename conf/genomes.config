/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    bulkAnnex — organism-specific annotation settings
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    genomes {
        'human' {
            annotation_db   = 'org.Hs.eg.db'
            kegg_organism   = 'hsa'
            msigdb_species  = 'Homo sapiens'
            ensembl_pattern = '^ENSG'
        }
        'mouse' {
            annotation_db   = 'org.Mm.eg.db'
            kegg_organism   = 'mmu'
            msigdb_species  = 'Mus musculus'
            ensembl_pattern = '^ENSMUSG'
        }
    }
}
