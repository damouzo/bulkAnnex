/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    bulkAnnex — base resource configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Cap a resource request at the user-defined maximum.
// Defined here so it is in scope for all process label closures.
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "WARNING: Could not check max memory '${params.max_memory}' -- using requested value: ${obj}"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "WARNING: Could not check max time '${params.max_time}' -- using requested value: ${obj}"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "WARNING: Could not check max cpus '${params.max_cpus}' -- using requested value: ${obj}"
            return obj
        }
    }
}

process {
    // Default: retry on common exit codes (OOM, node failure, etc.)
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Prevent OpenBLAS/OMP/MKL from spawning more threads than the job's CPU
    // allocation. Without this, OpenBLAS auto-detects all machine CPUs (e.g. 32)
    // and exhausts RLIMIT_NPROC on shared HPC nodes, causing segfaults (exit 139).
    // Using task.cpus ensures thread count matches SLURM's --cpus-per-task exactly.
    env.OPENBLAS_NUM_THREADS = { task.cpus as String }
    env.OMP_NUM_THREADS      = { task.cpus as String }
    env.MKL_NUM_THREADS      = { task.cpus as String }
    env.NUMEXPR_NUM_THREADS  = { task.cpus as String }

    withLabel: 'process_single' {
        cpus   = { check_max( 1                  , 'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt , 'memory' ) }
        time   = { check_max( 2.h  * task.attempt , 'time'   ) }
    }
    withLabel: 'process_medium' {
        cpus   = { check_max( 4                  , 'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h  * task.attempt , 'time'   ) }
    }
    withLabel: 'process_high' {
        cpus   = { check_max( 8                  , 'cpus'   ) }
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h  * task.attempt , 'time'   ) }
    }
}
