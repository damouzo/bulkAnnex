/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    bulkAnnex — per-module ext.args overrides
    Use this file to pass extra arguments to specific processes without touching
    the module definitions.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    withName: 'SINGULARITY_PULL' {
        // This process pulls the container — it must run natively (no container).
        container = null
    }
    withName: 'INPUT_CHECK' {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: 'copy',
            pattern: 'validated_*.csv'
        ]
    }
    withName: 'DESEQ2_QC' {
        publishDir = [
            path: { "${params.outdir}/qc" },
            mode: 'copy',
            pattern: '*.{pdf,png,tsv}'
        ]
    }
    withName: 'DESEQ2_NORMALIZATION' {
        ext.args   = { "--min_counts ${params.min_counts} --min_samples ${params.min_samples}" }
        publishDir = [
            path: { "${params.outdir}/normalization" },
            mode: 'copy',
            pattern: '*.{csv,rds,tsv}'
        ]
    }
    withName: 'DESEQ2_DGE' {
        ext.args   = { "--alpha ${params.padj_threshold} --lfc_thresh ${params.lfc_threshold}" }
        publishDir = [
            path: { "${params.outdir}/dge/${meta.contrast_id}" },
            mode: 'copy',
            pattern: '*.{csv,pdf,png,txt}'
        ]
    }
    withName: 'GSEA_ANALYSIS' {
        ext.args   = { "--pval_cutoff ${params.gsea_pval_cutoff} --min_gs ${params.gsea_min_gs_size} --max_gs ${params.gsea_max_gs_size}" }
        publishDir = [
            path: { "${params.outdir}/gsea/${meta.contrast_id}" },
            mode: 'copy',
            pattern: '*.{csv,pdf,png,rds}'
        ]
    }
    withName: 'SHINY_DASHBOARD' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: 'copy'
        ]
    }
}
