/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    bulkAnnex — test profile (NB4 demo data, 15 samples, 4 contrasts)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test using NB4 demo data (15 samples)'

    // Inputs
    input     = "${projectDir}/data_demo/samplesheet.csv"
    counts    = "${projectDir}/data_demo/counts/salmon.merged.gene_counts.tsv"
    contrasts = "${projectDir}/data_demo/contrasts.csv"
    organism  = 'human'
    outdir    = 'results_test'

    // Restrict resources for CI
    max_cpus   = 2
    max_memory = '8.GB'
    max_time   = '2.h'
}
