{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://raw.githubusercontent.com/YOUR_ORG/bulkAnnex/main/nextflow_schema.json",
    "title": "bulkAnnex pipeline parameters",
    "description": "Downstream bulk RNA-seq analysis: QC, normalization, DGE, GSEA, Shiny dashboard.",
    "type": "object",
    "definitions": {
        "input_output_options": {
            "title": "Input/output options",
            "type": "object",
            "fa_icon": "fas fa-terminal",
            "description": "Define where the pipeline should find input data and save output data.",
            "required": ["input", "counts", "contrasts", "outdir"],
            "properties": {
                "input": {
                    "type": "string",
                    "format": "file-path",
                    "mimetype": "text/csv",
                    "pattern": "\\.csv$",
                    "description": "Path to samplesheet CSV (columns: sample, condition, [batch]).",
                    "fa_icon": "fas fa-file-csv"
                },
                "counts": {
                    "type": "string",
                    "format": "file-path",
                    "mimetype": "text/tab-separated-values",
                    "pattern": "\\.tsv$",
                    "description": "Path to salmon.merged.gene_counts.tsv (gene_id, gene_name, samples...).",
                    "fa_icon": "fas fa-table"
                },
                "contrasts": {
                    "type": "string",
                    "format": "file-path",
                    "mimetype": "text/csv",
                    "pattern": "\\.csv$",
                    "description": "Path to contrasts CSV (columns: contrast_id, variable, reference, treatment).",
                    "fa_icon": "fas fa-not-equal"
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "Output directory for results.",
                    "fa_icon": "fas fa-folder-open",
                    "default": "results"
                }
            }
        },
        "reference_options": {
            "title": "Reference options",
            "type": "object",
            "fa_icon": "fas fa-dna",
            "description": "Organism and gene annotation settings.",
            "properties": {
                "organism": {
                    "type": "string",
                    "default": "human",
                    "description": "Organism for GSEA annotation. Supported: human, mouse.",
                    "fa_icon": "fas fa-frog",
                    "enum": ["human", "mouse"]
                }
            }
        },
        "analysis_options": {
            "title": "Analysis options",
            "type": "object",
            "fa_icon": "fas fa-cogs",
            "description": "Parameters controlling DESeq2 and GSEA behaviour.",
            "properties": {
                "run_gsea": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run GSEA after DGE analysis.",
                    "fa_icon": "fas fa-chart-bar"
                },
                "skip_dashboard": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip Shiny dashboard generation.",
                    "fa_icon": "fas fa-ban"
                },
                "min_counts": {
                    "type": "integer",
                    "default": 10,
                    "description": "Minimum count threshold for gene retention (applied per sample).",
                    "fa_icon": "fas fa-filter",
                    "minimum": 1
                },
                "min_samples": {
                    "type": "integer",
                    "default": 2,
                    "description": "Minimum number of samples with >= min_counts to retain a gene.",
                    "fa_icon": "fas fa-filter",
                    "minimum": 1
                },
                "normalization": {
                    "type": "string",
                    "default": "vst",
                    "description": "Normalization method: vst or rlog.",
                    "fa_icon": "fas fa-chart-line",
                    "enum": ["vst", "rlog"]
                },
                "padj_threshold": {
                    "type": "number",
                    "default": 0.05,
                    "description": "Adjusted p-value (FDR) threshold for DGE significance calls and plots.",
                    "fa_icon": "fas fa-percentage",
                    "minimum": 0,
                    "maximum": 1
                },
                "lfc_threshold": {
                    "type": "number",
                    "default": 1.0,
                    "description": "Log2 fold change threshold for significance calls and volcano plot.",
                    "fa_icon": "fas fa-sliders-h",
                    "minimum": 0
                },
                "gsea_pval_cutoff": {
                    "type": "number",
                    "default": 0.05,
                    "description": "Adjusted p-value cutoff for filtering GSEA dot plots.",
                    "fa_icon": "fas fa-percentage",
                    "minimum": 0,
                    "maximum": 1
                },
                "gsea_min_gs_size": {
                    "type": "integer",
                    "default": 15,
                    "description": "Minimum gene set size for GSEA.",
                    "fa_icon": "fas fa-compress-alt",
                    "minimum": 1
                },
                "gsea_max_gs_size": {
                    "type": "integer",
                    "default": 500,
                    "description": "Maximum gene set size for GSEA.",
                    "fa_icon": "fas fa-expand-alt",
                    "minimum": 2
                }
            }
        },
        "generic_options": {
            "title": "Generic options",
            "type": "object",
            "fa_icon": "fas fa-file-import",
            "description": "Less common options for the pipeline, typically set in a config file.",
            "properties": {
                "publish_dir_mode": {
                    "type": "string",
                    "default": "copy",
                    "description": "Method used to save pipeline results to output directory.",
                    "fa_icon": "fas fa-copy",
                    "enum": ["symlink", "rellink", "link", "copy", "copyNoFollow", "move"]
                },
                "max_memory": {
                    "type": "string",
                    "default": "128.GB",
                    "description": "Maximum amount of memory that can be requested for any single job.",
                    "fa_icon": "fas fa-memory"
                },
                "max_cpus": {
                    "type": "integer",
                    "default": 16,
                    "description": "Maximum number of CPUs that can be requested for any single job.",
                    "fa_icon": "fas fa-microchip",
                    "minimum": 1
                },
                "max_time": {
                    "type": "string",
                    "default": "240.h",
                    "description": "Maximum amount of time that can be requested for any single job.",
                    "fa_icon": "fas fa-clock"
                }
            }
        }
    },
    "allOf": [
        {"$ref": "#/definitions/input_output_options"},
        {"$ref": "#/definitions/reference_options"},
        {"$ref": "#/definitions/analysis_options"},
        {"$ref": "#/definitions/generic_options"}
    ]
}
